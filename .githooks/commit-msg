#!/bin/bash
# Reject commits with AI/vendor attribution

MSG=$(cat "$1")

PATTERNS=(
    "Generated with.*Claude"
    "Co-Authored-By:.*Claude"
    "Co-Authored-By:.*Anthropic"
    "Co-Authored-By:.*OpenAI"
    "Co-Authored-By:.*GPT"
    "Generated by AI"
    "claude.com"
    "openai.com"
)

for pattern in "${PATTERNS[@]}"; do
    if echo "$MSG" | grep -qiE "$pattern"; then
        echo "ERROR: Commit message contains AI attribution"
        echo "Pattern matched: $pattern"
        echo "Please remove AI/vendor attribution from commit message"
        exit 1
    fi
done

exit 0
